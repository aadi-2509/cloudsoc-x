# Copy this to .env and fill in your values
# Never commit the actual .env file

AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# OpenSearch domain endpoint (without trailing slash)
# e.g. https://search-cloudsoc-xxxxxxx.us-east-1.es.amazonaws.com
OPENSEARCH_ENDPOINT=

# Index name in OpenSearch
OPENSEARCH_INDEX=cloudsoc-alerts

# SNS topic ARN for critical/high alert notifications
SNS_TOPIC_ARN=

# Kinesis stream name (used by the event simulator)
KINESIS_STREAM_NAME=cloudsoc-events

# ipinfo.io token for IP enrichment (free tier = 50k req/month)
# Get one at https://ipinfo.io/signup
IPINFO_TOKEN=
